{
  "$schema": "https://openapi.vercel.sh",
  "buildCommand": "cd client && npm install && npm run build",
  "outputDirectory": "client/dist",
  "framework": "react",
  "env": {
    "VITE_API_URL": {
      "description": "Backend API URL for production deployment",
      "example": "https://smart-leads-api.onrender.com/api"
    }
  },
  "routes": [
    {
      "src": "^/(.*)",
      "dest": "/index.html"
    }
  ]
}
